 #ifndef ATH11K_CORE_H
@@ -29,6 +30,7 @@
 #include "thermal.h"
 #include "wow.h"
 #include "fw.h"
+#include "nss.h"
 
 #define SM(_v, _f)	(((_v) << _f##_S) & _f)
 
@@ -374,6 +376,9 @@ struct ath11k_vif {
 
 	struct ath11k_mgmt_frame_stats mgmt_stats;
 	struct dentry *debugfs_twt;
+
+	/* NSS WiFi offload state for this interface */
+	struct ath11k_vif_nss nss;
 };
 
 struct ath11k_vif_iter {
--- a/drivers/net/wireless/ath/ath11k/mac.c
+++ b/drivers/net/wireless/ath/ath11k/mac.c
@@ -5998,6 +5998,10 @@ static int ath11k_mac_op_add_interface(s
 		goto err_vdev_del;
 	}
 
+	ret = ath11k_nss_vif_add(ar, arvif);
+	if (ret)
+		ath11k_warn(ab, "NSS vif add failed, continuing without NSS offload\n");
+
 	mutex_unlock(&ar->conf_mutex);
 
 	return 0;
@@ -6085,6 +6089,8 @@ static void ath11k_mac_op_remove_interfa
 	struct ath11k_vif *arvif = ath11k_vif_to_arvif(vif);
 	struct ath11k_base *ab = ar->ab;
 
+	ath11k_nss_vif_del(ar, arvif);
+
 	mutex_lock(&ar->conf_mutex);
 
 	ath11k_dbg(ab, ATH11K_DBG_MAC, "mac remove interface (vdev %d)\n",
